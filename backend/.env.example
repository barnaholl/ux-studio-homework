# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Log level override (default: debug in dev, warn in production)
# Valid values: trace, debug, info, warn, error, fatal, silent
# LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path (relative to /backend). The dev.db file is committed to repo.
DATABASE_URL="file:./dev.db"

# ─── DigitalOcean Spaces (S3-compatible) ──────────────────────────────────────
# Your DO Spaces region (e.g. ams3, nyc3, fra1, sgp1, sfo3)
DO_SPACES_REGION=ams3

# Your DO Spaces endpoint URL — always https://{region}.digitaloceanspaces.com
DO_SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com

# The name of your Spaces bucket
DO_SPACES_BUCKET=your-bucket-name

# Spaces access key (created in DO API settings)
DO_SPACES_KEY=your-access-key

# Spaces secret key
DO_SPACES_SECRET=your-secret-key

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Secret used to sign access tokens — use a strong random value in production
JWT_SECRET=change-me-to-a-random-secret-in-production
